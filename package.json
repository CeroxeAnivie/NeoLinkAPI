{
  "name": "neolinkapi-monorepo",
  "version": "7.1.9",
  "private": true,
  "description": "Monorepo for the Java and Node.js NeoLinkAPI implementations.",
  "homepage": "https://github.com/CeroxeAnivie/NeoLinkAPI#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CeroxeAnivie/NeoLinkAPI.git"
  },
  "bugs": {
    "url": "https://github.com/CeroxeAnivie/NeoLinkAPI/issues"
  },
  "workspaces": [
    "packages/nodejs"
  ],
  "scripts": {
    "sync:version": "node scripts/sync-version.cjs",
    "build": "npm run build --workspace packages/nodejs",
    "test": "npm run test --workspace packages/nodejs",
    "build:all": "node scripts/run-gradle.cjs build && npm run build --workspace packages/nodejs",
    "test:all": "node scripts/run-gradle.cjs test && npm run test --workspace packages/nodejs",
    "build:all:offline": "node scripts/run-gradle.cjs build --offline && npm run build --workspace packages/nodejs",
    "test:all:offline": "node scripts/run-gradle.cjs test --offline && npm run test --workspace packages/nodejs",
    "check:shared": "node -e \"for (const f of ['shared/protocol/neolink-protocol.contract.json','shared/fixtures/nkm/nodes.valid.json','shared/fixtures/handshake/startup-responses.json']) JSON.parse(require('fs').readFileSync(f,'utf8'))\"",
    "build:nodejs": "npm run build --workspace packages/nodejs",
    "test:nodejs": "npm run test --workspace packages/nodejs",
    "build:java": "node scripts/run-gradle.cjs build",
    "test:java": "node scripts/run-gradle.cjs test",
    "build:java:offline": "node scripts/run-gradle.cjs build --offline",
    "test:java:offline": "node scripts/run-gradle.cjs test --offline",
    "build:java:android": "node scripts/run-gradle-android.cjs build",
    "test:java:android": "node scripts/run-gradle-android.cjs test",
    "test:java:android:fast": "node scripts/run-gradle-android.cjs testDebugUnitTest"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
