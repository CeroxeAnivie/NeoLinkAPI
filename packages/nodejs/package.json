{
  "name": "neolinkapi",
  "version": "7.1.9",
  "description": "Node.js API client for NeoLink TCP/UDP tunnels.",
  "author": "Ceroxe",
  "homepage": "https://github.com/CeroxeAnivie/NeoLinkAPI#readme",
  "bugs": {
    "url": "https://github.com/CeroxeAnivie/NeoLinkAPI/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CeroxeAnivie/NeoLinkAPI.git",
    "directory": "packages/nodejs"
  },
  "type": "module",
  "main": "dist-cjs/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist-cjs/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "dist-cjs",
    "!dist/test",
    "!dist/test/**",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/clean-dist.cjs && tsc -p tsconfig.json && tsc -p tsconfig.cjs.json && node scripts/write-cjs-package.cjs",
    "test": "npm run build && node --test dist/test/*.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^6.0.3"
  },
  "license": "MIT"
}
